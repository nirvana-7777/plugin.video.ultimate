<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.ultimate"
       name="Ultimate"
       version="1.3.13"
       provider-name="Nirvana777">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.inputstreamhelper" version="0.5.0" optional="true"/>
    <import addon="inputstream.adaptive" version="21.5.0"/>
    <import addon="script.service.ultimate" version="1.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="addon.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Ultimate Streaming</summary>
    <description lang="en_GB">Browse and stream channels, events and VOD content from your Ultimate server. Supports DRM (Widevine/PlayReady) via InputStream Adaptive.</description>
    <news lang="en_GB">
      v1.1.0: Live Now filter, VOD search, EPG in channel listing, DRM from manifest header, caching, single-provider shortcut, human-readable Now Playing titles.
    </news>
    <source>https://github.com/nirvana-7777/plugin.video.ultimate</source>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
    <platform>all</platform>
    <license>GPL-2.0-only</license>
  </extension>
</addon>
